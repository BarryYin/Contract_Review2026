# ContractAI 环境变量配置
# 复制此文件为 .env 并填入实际值

# LLM API 配置（必需）
# 支持任何 OpenAI 兼容的 API
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.stepfun.com
LLM_MODEL=step-3.5-flash

# OCR 服务（使用视觉模型，同上）
STEP_API_KEY=your_step_api_key_here

# DeepSeek 备用（可选）
DEEPSEEK_API_KEY=

# OpenAI 备用（可选）
OPENAI_API_KEY=

# 服务配置
# HOST=0.0.0.0
# PORT=8000
